  const ctx = getTargetUserId(req, user);
  if ("error" in ctx) {
    return res.status(403).json({ error: ctx.error });
  }

  const outfits = dbInMemory.savedOutfits[ctx.targetUserId] || [];
  res.json({ outfits });
});

app.post("/api/saved-outfits", (req, res) => {
  const user = getSessionUser(req);
  if (!user) return res.status(401).json({ error: "Unauthorized access" });

  const ctx = getTargetUserId(req, user);
  if ("error" in ctx) {
    return res.status(403).json({ error: ctx.error });
  }

  const { recommendationId, name, vibe, explanation, top, bottom, outerwear, weather, mood, occasion, colorHarmony } = req.body;
  if (!name || !top || !bottom) {
    return res.status(400).json({ error: "Details missing to save this outfit combo." });
  }

  const newSaved: SavedOutfit = {
    id: `saved_${Date.now()}`,
    userId: ctx.targetUserId,
    recommendationId: recommendationId || `custom_${Date.now()}`,
    name,
    vibe: vibe || "Custom curated",
    explanation: explanation || "",
    top,
    bottom,
    outerwear,
    weather,
    mood,
    occasion,
    colorHarmony,
    feedback: null,
    savedAt: new Date().toISOString()
  };

  if (!dbInMemory.savedOutfits[ctx.targetUserId]) {
    dbInMemory.savedOutfits[ctx.targetUserId] = [];
  }

  // Prevent duplicate saves of similar components
  const existing = dbInMemory.savedOutfits[ctx.targetUserId].find(o => 
    o.top.id === top.id && o.bottom.id === bottom.id && o?.outerwear?.id === outerwear?.id
  );

  if (existing) {
    return res.json({ outfit: existing, message: "Outfit is already saved in your wardrobe journal." });
  }

  dbInMemory.savedOutfits[ctx.targetUserId].unshift(newSaved);
  saveDb();
  res.json({ outfit: newSaved });
});

app.post("/api/saved-outfits/:id/feedback", (req, res) => {
  const user = getSessionUser(req);
  if (!user) return res.status(401).json({ error: "Unauthorized access" });

  const ctx = getTargetUserId(req, user);
  if ("error" in ctx) {
    return res.status(403).json({ error: ctx.error });
  }

  const { id } = req.params;
  const { feedback } = req.body; // 'like' | 'dislike' | null

  const outfits = dbInMemory.savedOutfits[ctx.targetUserId] || [];
