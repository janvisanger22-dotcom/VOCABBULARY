  if (!outfit) {
    return res.status(404).json({ error: "Saved outfit not found." });
  }

  outfit.feedback = feedback;
  saveDb();
  res.json({ outfit });
});

app.delete("/api/saved-outfits/:id", (req, res) => {
  const user = getSessionUser(req);
  if (!user) return res.status(401).json({ error: "Unauthorized access" });

  const ctx = getTargetUserId(req, user);
  if ("error" in ctx) {
    return res.status(403).json({ error: ctx.error });
  }

  const { id } = req.params;
  const outfits = dbInMemory.savedOutfits[ctx.targetUserId] || [];
  const index = outfits.findIndex(o => o.id === id);
  if (index === -1) {
    return res.status(404).json({ error: "Saved outfit not found." });
  }

