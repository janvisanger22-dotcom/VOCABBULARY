app.post("/api/recommendations/generate", async (req, res) => {
  const user = getSessionUser(req);
  if (!user) return res.status(401).json({ error: "Unauthorized access" });

  const ctx = getTargetUserId(req, user);
  if ("error" in ctx) {
    return res.status(403).json({ error: ctx.error });
  }

  const { weather, mood, occasion } = req.body;
  if (!weather || !mood || !occasion) {
    return res.status(400).json({ error: "Weather, mood, and occasion are required parameters." });
  }

  const allItems = dbInMemory.wardrobe[ctx.targetUserId] || [];
  if (allItems.length === 0) {
    return res.status(400).json({ 
      error: "This digital wardrobe is empty. Please add some clothes to construct combinations." 
    });
  }

  const targetProfile = dbInMemory.users.find(u => u.id === ctx.targetUserId) || user;

  // Weather pre-filtering
  const filteredItems = filterWardrobeItemsForWeather(allItems, weather);
  
  // Sort wardrobe items so that custom user-uploaded garments (IDs not starting with "seed_") come first before presets
  const sortByUploadPriority = (a: WardrobeItem, b: WardrobeItem) => {
    const aIsUploaded = !a.id.startsWith("seed_");
    const bIsUploaded = !b.id.startsWith("seed_");
    if (aIsUploaded && !bIsUploaded) return -1;
    if (!aIsUploaded && bIsUploaded) return 1;
    // Keep chronological order if same seed/upload group
    return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime();
  };

  const sortedFilteredItems = [...filteredItems].sort(sortByUploadPriority);
  
  const tops = sortedFilteredItems.filter(i => i.category === "Top");
  const bottoms = sortedFilteredItems.filter(i => i.category === "Bottom");
  const outerwear = sortedFilteredItems.filter(i => i.category === "Outerwear");

  if (tops.length === 0 || bottoms.length === 0) {
    return res.status(400).json({ 
      error: `To create recommendations, we need at least one Top and one Bottom matching the ${weather} condition. Currently there are: ${tops.length} Tops and ${bottoms.length} Bottoms in this wardrobe for this weather.` 
    });
  }

  // Construct structured text prompt for Gemini AI model with high priority labeling for custom uploads
  const topsList = tops.map(t => {
    const priority = !t.id.startsWith("seed_") ? "[USER CUSTOM UPLOADED - HIGH PRIORITY]" : "[Starter Preset]";
    return `ID: ${t.id} - ${t.name} ${priority} (Color: ${t.color}, Material: ${t.material}, Occasions: ${t.occasions.join(", ")})`;
  }).join("\n");

  const bottomsList = bottoms.map(b => {
    const priority = !b.id.startsWith("seed_") ? "[USER CUSTOM UPLOADED - HIGH PRIORITY]" : "[Starter Preset]";
    return `ID: ${b.id} - ${b.name} ${priority} (Color: ${b.color}, Material: ${b.material}, Occasions: ${b.occasions.join(", ")})`;
  }).join("\n");

  const outerwearList = outerwear.map(o => {
    const priority = !o.id.startsWith("seed_") ? "[USER CUSTOM UPLOADED - HIGH PRIORITY]" : "[Starter Preset]";
    return `ID: ${o.id} - ${o.name} ${priority} (Color: ${o.color}, Material: ${o.material}, Occasions: ${o.occasions.join(", ")})`;
  }).join("\n");

  const prompt = `You are an expert AI Editorial Stylist representing a custom high-end Digital Wardrobe application.
The user wants outfits configured from their specific wardrobe lists. Do not invent items outside of these lists.
Select clothing items exclusively using their IDs from the provided lists below.

CRITICAL PRIORITIZATION MANDATE:
- The items marked with "[USER CUSTOM UPLOADED - HIGH PRIORITY]" represent real-world physical items uploaded by the user.
- You MUST prioritize selecting these high priority user-uploaded items for the outfit combinations.
- Only utilize "[Starter Preset]" items when absolutely necessary to build a complete outfit (e.g., if there are no user-uploaded bottoms or outerwear available).
- Highlight combinations showcasing the user's uploaded clothes in the styling feedback.

CONTEXT CRITERIA:
- Selected Weather: ${weather}
- Chosen Mood aesthetic or Color palette: ${mood}
- Occasion context: ${occasion}
- User normal styling taste: Vibe = ${targetProfile.stylePreferences?.stylingVibe || "Minimalist"}, Occasions = ${targetProfile.stylePreferences?.preferredOccasions?.join(", ") || "Casual"}, Accent preference = ${targetProfile.stylePreferences?.accentColors?.join(", ") || "Neutrals"}.

THE USER'S EXCLUSIVE WARDROBE LISTS:

TOP ITEMS:
${topsList || "None available"}

BOTTOM ITEMS:
${bottomsList || "None available"}

OUTERWEAR ITEMS (Optional, apply appropriate items if weather is cold or sunny as defined by rules):
${outerwearList || "None available"}

WEATHER STYLING RULES:
1. Cold Weather: Must prioritize outerwear options (Blazers, coats, jackets) alongside tops and bottoms.
2. Warm Weather: Must exclude blazer and wool coats completely. Suggest breezy light Tops + Bottoms.
3. Sunny Weather: May include light jackets/blazers but strictly exclude coats.

TASK:
Generate exactly 3 stylish outfit options. Ensure that each outfit represents a cohesive look that matches the Selected Weather, Chosen Mood, and Occasion.
For each outfit, select one Top ID, one Bottom ID, and optionally one Outerwear ID if appropriate.
Explain the color harmony (e.g., Mono-linear Neutral, Complementary bold contrasts, Analogous pairing).
Explain the choice in detail with premium editorial taste.

Return a JSON array where each entry conforms strictly to this schema structure:
[
  {
    "name": "Classy title of the outfit (e.g., Casual Indigo Breeze)",
    "vibe": "Quick look style tag (e.g., Tailored Minimalist, Relaxed Academic)",
    "topId": "The exact ID of the matching Top item",
    "bottomId": "The exact ID of the matching Bottom item",
    "outerwearId": "The exact ID of the matching Outerwear item or empty/null if none selected",
    "explanation": "High-fashion styling tips and rationale why this combination fits the chosen occasion, mood, weather, and profile style",
    "colorHarmony": "Analysis of the look's color layout theory"
  }
]`;

  try {
    const isGeminiEnabled = !!process.env.GEMINI_API_KEY;
    let suggestions: any[] = [];

    if (isGeminiEnabled) {
      try {
        const response = await generateWithRetryAndFallback({
          contents: prompt,
          config: {
            responseMimeType: "application/json",
            responseSchema: {
              type: Type.ARRAY,
              items: {
                type: Type.OBJECT,
                properties: {
                  name: { type: Type.STRING },
                  vibe: { type: Type.STRING },
                  topId: { type: Type.STRING },
                  bottomId: { type: Type.STRING },
                  outerwearId: { type: Type.STRING },
                  explanation: { type: Type.STRING },
                  colorHarmony: { type: Type.STRING }
                },
                required: ["name", "vibe", "topId", "bottomId", "explanation", "colorHarmony"]
              }
            }
          }
        });

        const responseText = response.text || "[]";
        suggestions = JSON.parse(responseText.trim());
      } catch (geminiError: any) {
        console.error("Gemini API call failed even after retries and fallbacks. Falling back seamlessly to local matching model...", geminiError);
        suggestions = generateOfflineSuggestions(tops, bottoms, outerwear, weather, mood, occasion);
      }
    } else {
      console.log("Gemini API key not found, using responsive fashion-matcher logic");
      suggestions = generateOfflineSuggestions(tops, bottoms, outerwear, weather, mood, occasion);
    }

    // Map recommendation item IDs back into full WardrobeItem structures
    const recommendations: OutfitRecommendation[] = [];
    
    for (let i = 0; i < suggestions.length; i++) {
        const sug = suggestions[i];
        const resolvedTop = allItems.find(item => item.id === sug.topId);
        const resolvedBottom = allItems.find(item => item.id === sug.bottomId);
        const resolvedOuter = sug.outerwearId ? allItems.find(item => item.id === sug.outerwearId) : undefined;

        // Graceful fallback resolver if IDs don't match exactly due to LLM hallucinations
        const finalTop = resolvedTop || tops[i % tops.length];
        const finalBottom = resolvedBottom || bottoms[i % bottoms.length];
        const finalOuter = resolvedOuter || (outerwear.length > 0 && weather !== "Warm" ? outerwear[i % outerwear.length] : undefined);

        recommendations.push({
          id: `rec_${Date.now()}_${i}`,
          name: sug.name || "Curated Daily Look",
          vibe: sug.vibe || "Custom Style",
          explanation: sug.explanation || "A beautiful, weather-appropriate coordination built entirely from your digital closet.",
          top: finalTop,
          bottom: finalBottom,
          outerwear: finalOuter,
          weather,
          mood,
          occasion,
          colorHarmony: sug.colorHarmony || "Complementary Neutrals"
        });
    }

    res.json({ recommendations });
  } catch (error) {
    console.error("Failed to generate recommendations:", error);
    res.status(500).json({ error: "Failed to create recommendations. Please try again." });
  }
});

