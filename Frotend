// Helper function to generate content with exponential backoff and models fallback
async function generateWithRetryAndFallback(params: {
  contents: string;
  config: any;
}) {
  const modelsToTry = ["gemini-3.5-flash", "gemini-3.1-flash-lite"];
  let lastError: any = null;

  for (const model of modelsToTry) {
    let delay = 600; // start with 600ms backoff
    for (let attempt = 0; attempt < 3; attempt++) {
      try {
        console.log(`Querying Gemini with model ${model} (attempt ${attempt + 1}/3)...`);
        const response = await ai.models.generateContent({
          model,
          contents: params.contents,
          config: params.config,
        });
        return response;
      } catch (err: any) {
        lastError = err;
        const errMsg = err?.message || String(err);
        const isTransient = errMsg.includes("503") || 
                            errMsg.includes("high demand") || 
                            errMsg.includes("UNAVAILABLE") || 
                            errMsg.includes("ResourceExhausted") || 
                            errMsg.includes("429") ||
                            err?.status === 503 ||
                            err?.status === 429;
        
        console.warn(`Attempt ${attempt + 1} with model ${model} failed. Error: ${errMsg}`);
        
        // Wait with exponential backoff before next attempt
        await new Promise((resolve) => setTimeout(resolve, delay));
        delay *= 2;
      }
    }
    console.warn(`All attempts failed for model ${model}. Trying next available fallback model...`);
  }

  throw lastError || new Error("Failed to generate content with all fallback models.");
}

// Fallback offline dynamic matching helper logic if Gemini is completely offline or unavailable
function generateOfflineSuggestions(
  tops: WardrobeItem[],
  bottoms: WardrobeItem[],
  outerwear: WardrobeItem[],
  weather: string,
  mood: string,
  occasion: string
) {
  const suggestions: any[] = [];
  const defaultOptions = [
    { name: "Urban Comfort Classic", vibe: "Casual Minimalist", colorHarmony: "Monochromatic Neutral" },
    { name: "Smart Business Casual", vibe: "Workplace Elegant", colorHarmony: "Analogous Contrast" },
    { name: "Sunny Weekend Breeze", vibe: "Relaxed Contemporary", colorHarmony: "Breezy Pastel Neutral" }
  ];

  for (let i = 0; i < Math.min(3, tops.length * bottoms.length); i++) {
    const topItem = tops[i % tops.length];
    const bottomItem = bottoms[(i + 1) % bottoms.length];
    const outerItem = outerwear.length > 0 && weather !== "Warm" ? outerwear[i % outerwear.length] : undefined;
    const fallbackOption = defaultOptions[i % defaultOptions.length];

    suggestions.push({
      name: fallbackOption.name,
      vibe: fallbackOption.vibe,
      topId: topItem.id,
      bottomId: bottomItem.id,
      outerwearId: outerItem ? outerItem.id : null,
      explanation: `This curated lookup pairs your ${topItem.name} in ${topItem.color} elegantly with the ${bottomItem.name} to form a stunning ${occasion}-ready silhouette. Fits your ${mood} theme perfectly matching the prevailing ${weather} weather (Aesthetic Fallback).`,
      colorHarmony: fallbackOption.colorHarmony
    });
  }
  return suggestions;
}

// Weather pre-filtering implementation
function filterWardrobeItemsForWeather(items: WardrobeItem[], weather: "Cold" | "Warm" | "Sunny"): WardrobeItem[] {
  return items.filter(item => {
    const sub = item.subcategory?.toLowerCase() || "";
    if (weather === "Cold") {
      // Cold: Blazers, long coats, all other tops/bottoms.
      return true;
    } else if (weather === "Warm") {
      // Warm: Everything excluding blazers and coats.
      return !(sub === "blazers" || sub === "coats");
    } else if (weather === "Sunny") {
      // Sunny: Everything excluding coats, including jackets.
      return sub !== "coats";
    }
    return true;
  });
}

// Authentic user extraction middleware from simple simulation cookie/header
function getSessionUser(req: express.Request): User | null {
  const authHeader = req.headers.authorization;
  if (!authHeader || !authHeader.startsWith("Bearer ")) {
    return null;
  }
  const email = Buffer.from(authHeader.split(" ")[1], "base64").toString("utf-8");
  let user = dbInMemory.users.find(u => u.email.toLowerCase() === email.toLowerCase());
  
  // Re-constitute user session profile if they have a valid email token but the ephemeral db was recycled
  if (!user && email && email.includes("@")) {
    console.log(`Ephemeral state recovery: Reconstituting user database record for ${email}`);
    user = {
      id: `user_${Date.now()}`,
      email: email.toLowerCase(),
      passwordHash: "session_reconstituted",
      profileName: email.split("@")[0],
      stylePreferences: {
        accentColors: ["Neutral", "Dark"],
        preferredOccasions: ["Casual", "Formal"],
        stylingVibe: "Minimalist"
      }
    };
    dbInMemory.users.push(user);
    saveDb();
  }

  if (!user) return null;
  return {
    id: user.id,
    email: user.email,
    profileName: user.profileName,
    stylePreferences: user.stylePreferences
  };
}

// Target User Context helper to resolve sharing permissions
function getTargetUserId(req: express.Request, currentUser: User): { targetUserId: string, targetUserEmail: string, isSharedAccess: boolean } | { error: string } {
  const queryOwnerEmail = (req.query.ownerEmail as string || req.body.ownerEmail as string);
  if (!queryOwnerEmail || queryOwnerEmail.toLowerCase() === currentUser.email.toLowerCase()) {
    return { targetUserId: currentUser.id, targetUserEmail: currentUser.email, isSharedAccess: false };
  }

  // Check if queryOwnerEmail has given access to currentUser.email
  const shares = dbInMemory.sharingAccess || [];
  const hasAccess = shares.some(s => 
    s.ownerEmail.toLowerCase() === queryOwnerEmail.toLowerCase() &&
    s.friendEmail.toLowerCase() === currentUser.email.toLowerCase()
  );

  if (!hasAccess) {
    return { error: `You do not have permission to access the wardrobe of ${queryOwnerEmail}.` };
  }

  // Find target user by email
  const targetUser = dbInMemory.users.find(u => u.email.toLowerCase() === queryOwnerEmail.toLowerCase());
  if (!targetUser) {
    const emailKey = queryOwnerEmail.toLowerCase();
    const tempUser = {
      id: `user_${Date.now()}`,
      email: emailKey,
      passwordHash: "session_reconstituted",
      profileName: emailKey.split("@")[0],
      stylePreferences: {
        accentColors: ["Neutral", "Dark"],
        preferredOccasions: ["Casual", "Formal"],
        stylingVibe: "Minimalist"
      }
    };
    dbInMemory.users.push(tempUser);
    saveDb();
    return { targetUserId: tempUser.id, targetUserEmail: tempUser.email, isSharedAccess: true };
  }

  return { targetUserId: targetUser.id, targetUserEmail: targetUser.email, isSharedAccess: true };
}

