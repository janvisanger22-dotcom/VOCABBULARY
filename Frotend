app.get("/api/sharing/access", (req, res) => {
  const user = getSessionUser(req);
  if (!user) return res.status(401).json({ error: "Unauthorized access" });

  const shares = dbInMemory.sharingAccess || [];
  
  // People I've shared my wardrobe with
  const sharedAccessByMe = shares.filter(s => 
    s.ownerId === user.id || s.ownerEmail.toLowerCase() === user.email.toLowerCase()
  );

  // Wardrobes shared with me by friends
  const sharedAccessToMe = shares.filter(s => 
    s.friendEmail.toLowerCase() === user.email.toLowerCase()
  );

  res.json({ sharedAccessByMe, sharedAccessToMe });
});

app.post("/api/sharing/grant", (req, res) => {
  const user = getSessionUser(req);
  if (!user) return res.status(401).json({ error: "Unauthorized access" });

  let { friendEmail } = req.body;
  if (!friendEmail || typeof friendEmail !== "string") {
    return res.status(400).json({ error: "Friend email is a required payload value." });
  }

  friendEmail = friendEmail.trim().toLowerCase();
  if (friendEmail === user.email.toLowerCase()) {
    return res.status(400).json({ error: "You cannot share your wardrobe with your own email account." });
  }

  // Check email validation
  if (!friendEmail.includes("@") || friendEmail.length < 5) {
    return res.status(400).json({ error: "Please specify a valid friend email address." });
  }

  if (!dbInMemory.sharingAccess) {
    dbInMemory.sharingAccess = [];
  }

  const existingShare = dbInMemory.sharingAccess.find(s => 
    (s.ownerEmail.toLowerCase() === user.email.toLowerCase() || s.ownerId === user.id) &&
    s.friendEmail.toLowerCase() === friendEmail
  );

  if (existingShare) {
    return res.status(400).json({ error: "You have already shared access with this friend." });
  }

  const newShare: SharingAccess = {
    id: `share_${Date.now()}`,
    ownerId: user.id,
    ownerEmail: user.email.toLowerCase(),
    ownerProfileName: user.profileName || user.email.split("@")[0],
    friendEmail,
    createdAt: new Date().toISOString()
  };

  dbInMemory.sharingAccess.push(newShare);
  saveDb();

  res.json({ success: true, share: newShare });
});

app.post("/api/sharing/revoke", (req, res) => {
  const user = getSessionUser(req);
  if (!user) return res.status(401).json({ error: "Unauthorized access" });

  const { shareId } = req.body;
  if (!shareId) {
    return res.status(400).json({ error: "Access share record key is required." });
  }

  if (!dbInMemory.sharingAccess) {
    dbInMemory.sharingAccess = [];
  }

  const index = dbInMemory.sharingAccess.findIndex(s => s.id === shareId);
  if (index === -1) {
    return res.status(404).json({ error: "Sharing permission record not found." });
  }

  const shareRecord = dbInMemory.sharingAccess[index];
  
  // Only owner or the invited friend can revoke that access link
  const isOwner = shareRecord.ownerId === user.id || shareRecord.ownerEmail.toLowerCase() === user.email.toLowerCase();
  const isUserFriend = shareRecord.friendEmail.toLowerCase() === user.email.toLowerCase();

  if (!isOwner && !isUserFriend) {
    return res.status(403).json({ error: "You are not authorized to revoke this styling access." });
  }

  dbInMemory.sharingAccess.splice(index, 1);
  saveDb();

  res.json({ success: true, message: "Styling permission revoked successfully." });
});


