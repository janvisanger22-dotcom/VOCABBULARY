// Database structure
interface SharingAccess {
  id: string;
  ownerId: string;
  ownerEmail: string;
  ownerProfileName: string;
  friendEmail: string;
  createdAt: string;
}

interface LocalDBSchema {
  users: Array<User & { passwordHash: string }>;
  wardrobe: Record<string, WardrobeItem[]>; // userId -> items
  savedOutfits: Record<string, SavedOutfit[]>; // userId -> saved outfits
  sharingAccess?: SharingAccess[]; // optional/new field for sharing wardrobe with friends
}

let dbInMemory: LocalDBSchema = {
  users: [],
  wardrobe: {},
  savedOutfits: {},
  sharingAccess: []
};

// Initialize database
function initDb() {
  try {
    if (!fs.existsSync(DATA_DIR)) {
      fs.mkdirSync(DATA_DIR, { recursive: true });
    }
    if (fs.existsSync(DB_FILE)) {
      const data = fs.readFileSync(DB_FILE, "utf-8");
      try {
        dbInMemory = JSON.parse(data);
        if (!dbInMemory.users) dbInMemory.users = [];
        if (!dbInMemory.wardrobe) dbInMemory.wardrobe = {};
        if (!dbInMemory.savedOutfits) dbInMemory.savedOutfits = {};
        if (!dbInMemory.sharingAccess) dbInMemory.sharingAccess = [];
      } catch (e) {
        console.error("Error reading database file, resetting database to empty structure.", e);
        saveDb();
      }
    } else {
      saveDb();
    }
  } catch (err) {
    console.error("Failed to initialize database folder / structure:", err);
  }
}

function saveDb() {
  try {
    fs.writeFileSync(DB_FILE, JSON.stringify(dbInMemory, null, 2), "utf-8");
  } catch (e) {
    console.error("Failed to persist database file", e);
  }
}

