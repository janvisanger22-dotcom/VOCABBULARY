app.delete("/api/wardrobe/:id", (req, res) => {
  const user = getSessionUser(req);
  if (!user) return res.status(401).json({ error: "Unauthorized access" });

  const ctx = getTargetUserId(req, user);
  if ("error" in ctx) {
    return res.status(403).json({ error: ctx.error });
  }

  const { id } = req.params;
  const items = dbInMemory.wardrobe[ctx.targetUserId] || [];
  const index = items.findIndex(item => item.id === id);
  if (index === -1) {
    return res.status(404).json({ error: "Clothing item not found." });
  }

  items.splice(index, 1);
  saveDb();
  res.json({ success: true, message: "Item deleted successfully." });
});

